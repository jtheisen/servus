<?xml version="1.0" encoding="utf-8" ?>
<nlog
  xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
>
  <variable name="logdir" value="../../../log" />
  <variable name="name" value="???" />

  <targets async="true">
    <target
      xsi:type="Debugger"
      name="debugger"
      layout="${level:uppercase=true} ${logger} ${message}"
    />
    <target
      xsi:type="AtomFile"
      name="file-all"
      layout="${var:name} ${date:universalTime=true:format=dd HH\:mm\:ss:culture=en}|${logger}|${message}"
      fileName="${logdir}/all"
      keepFileOpen="true"
      concurrentWrites="true"
      maxArchiveFiles="8"
      archiveAboveSize="65536"
    />
    <target
      xsi:type="AtomFile"
      name="file-error"
      layout="${var:name} ${date:universalTime=true:format=dd HH\:mm\:ss:culture=en}|${logger}|${message}${onexception:${newline}${exception:format=ToString}}"
      fileName="${logdir}/error"
      keepFileOpen="true"
      concurrentWrites="true"
      maxArchiveFiles="8"
      archiveAboveSize="65536"
    />
  </targets>
</nlog>
